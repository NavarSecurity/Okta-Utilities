# Target Okta org where selected objects will be recreated.
# Use the base org URL only. Do not include /admin, /oauth2, or /api/v1.
OKTA_TARGET_ORG_URL=https://target-org.okta.com

# API token for the TARGET org. The token must have permission to create the selected resource types.
# Do not include the literal "SSWS" prefix here.
OKTA_TARGET_API_TOKEN=replace_with_target_org_api_token

# Optional aliases supported by the utility for convenience:
# OKTA_ORG_URL=https://target-org.okta.com
# OKTA_API_TOKEN=replace_with_target_org_api_token
