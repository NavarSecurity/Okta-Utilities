{
  "outputDirectory": "output",
  "includeApiTokens": false,
  "includeOAuthApps": true,
  "includeAppGrants": true,
  "includeClientRoleAssignments": true,
  "includeInactiveApps": false,
  "continueOnRequestError": true,
  "redactSensitiveValues": true,
  "appSelection": {
    "mode": "all_oidc",
    "appIds": [],
    "appNames": [],
    "appFile": "input/apps.txt"
  },
  "riskRules": {
    "staleApiTokenDays": 90,
    "oldApiTokenDays": 365,
    "staleAppDays": 180,
    "highRiskScopes": [
      "okta.apiTokens.manage",
      "okta.apps.manage",
      "okta.authorizationServers.manage",
      "okta.clients.manage",
      "okta.groups.manage",
      "okta.policies.manage",
      "okta.roles.manage",
      "okta.users.manage"
    ],
    "highRiskRoles": [
      "SUPER_ADMIN",
      "ORG_ADMIN",
      "API_ACCESS_MANAGEMENT_ADMIN",
      "APP_ADMIN",
      "USER_ADMIN",
      "GROUP_ADMIN",
      "CUSTOM"
    ],
    "flagClientWithScopesButNoRoles": true,
    "flagClientWithRolesButNoScopes": true,
    "flagBroadNetworkApiTokens": true
  },
  "timeoutSeconds": 30
}
