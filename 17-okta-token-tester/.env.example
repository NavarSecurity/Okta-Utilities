# Normal Okta org URL. Do not use the -admin Admin Console URL.
OKTA_ORG_URL=https://your-org.okta.com

# Optional OAuth client used for client credentials, authorization code exchange, and introspection tests.
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Optional tokens for local JWT validation or introspection tests.
# Do not commit real tokens.
OKTA_ACCESS_TOKEN=
OKTA_ID_TOKEN=

# Optional authorization-code flow values.
OKTA_AUTHORIZATION_CODE=
OKTA_CODE_VERIFIER=
