{
  "outputDirectory": "output",
  "includeUserSchemas": true,
  "userSchemaIds": [
    "default"
  ],
  "includeGroupSchema": false,
  "includeAppSchemas": true,
  "appSelection": {
    "mode": "all",
    "appIds": [],
    "appNames": [],
